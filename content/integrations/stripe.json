{
  "id": "stripe",
  "name": "Stripe",
  "version": "1.0.0",
  "description": "Payments, invoices, and billing",
  "icon": "card",
  "profile": "charge",
  "mcp": {
    "command": "npx",
    "args": ["-y", "@stripe/mcp@latest"]
  },
  "credentials": {
    "fields": [
      { "key": "apiKey", "label": "API Key", "type": "password", "placeholder": "sk_live_..." }
    ],
    "envMapping": { "STRIPE_SECRET_KEY": "apiKey" }
  },
  "oauth": null,
  "toolGating": {
    "default": {
      "executionMapping": {},
      "staticExecution": { "action_type": "read" }
    },
    "overrides": {
      "create_payment_link": {
        "executionMapping": {
          "unit_amount": { "field": "amount", "divisor": 100 },
          "currency": "currency"
        },
        "staticExecution": { "action_type": "charge" }
      },
      "create_price": {
        "executionMapping": {
          "unit_amount": { "field": "amount", "divisor": 100 },
          "currency": "currency"
        },
        "staticExecution": { "action_type": "charge" }
      },
      "create_invoice_item": {
        "executionMapping": {
          "amount": { "field": "amount", "divisor": 100 },
          "currency": "currency"
        },
        "staticExecution": { "action_type": "charge" }
      },
      "create_refund": {
        "executionMapping": {
          "amount": { "field": "amount", "divisor": 100 }
        },
        "staticExecution": { "action_type": "refund" }
      },
      "create_subscription": {
        "executionMapping": {},
        "staticExecution": { "action_type": "subscribe" }
      },
      "cancel_subscription": {
        "executionMapping": {},
        "staticExecution": { "action_type": "subscribe" }
      },
      "update_subscription": {
        "executionMapping": {},
        "staticExecution": { "action_type": "subscribe" }
      },
      "retrieve_balance": { "category": "read" },
      "list_invoices": { "category": "read" },
      "list_subscriptions": { "category": "read" },
      "list_payment_methods": { "category": "read" }
    }
  },
  "setupHint": "Use a test key (sk_test_...) for development.",
  "setupGuide": [
    {
      "title": "Create a Stripe account",
      "description": "Sign up at stripe.com if you don't have an account yet.",
      "link": "https://dashboard.stripe.com/register"
    },
    {
      "title": "Get your API key",
      "description": "Go to Developers > API keys in your Stripe dashboard. Copy the Secret Key (starts with sk_live_ or sk_test_).",
      "link": "https://dashboard.stripe.com/apikeys"
    },
    {
      "title": "Enter your key below",
      "description": "Paste your Secret Key in the field below. Use a test key (sk_test_...) for development."
    }
  ]
}
